# ============================================
# Nutri-Guesser – Umgebungsvariablen
# ============================================
# Kopiere diese Datei zu '.env' und befülle die Werte.
# ACHTUNG: Die .env-Datei darf NICHT ins Git-Repository eingecheckt werden!

# --- Datenbank (H2) ---
DB_USER=CALORIE_APP
DB_PASSWORD=changeme_secure_password
DB_JDBC_URL=jdbc:h2:file:/data/h2/calorie-game-db;NON_KEYWORDS=USER

# --- Ports ---
FRONTEND_PORT=3000
BACKEND_PORT=8080

# --- CORS ---
# Kommaseparierte Origins, die auf das Backend zugreifen dürfen
CORS_ORIGINS=http://localhost:3000

# --- Frontend API URL ---
# Wird zur Build-Zeit in Vite eingebettet (VITE_-Präfix erforderlich).
# Standard '/api' funktioniert mit dem Nginx-Reverse-Proxy.
VITE_API_BASE_URL=/api

# --- Docker Images (optional, für Registry-Push) ---
FRONTEND_IMAGE=nutri-guesser-frontend:latest
BACKEND_IMAGE=nutri-guesser-backend:latest

